---
import Layout from "../layouts/Default.astro";
import { getCollection } from "astro:content";
import { supabase } from "../lib/supabase";

// Fetch all blog posts
const posts = await getCollection("blog");

// Fetch all views from Supabase
const { data: viewsData, error } = await supabase
  .from("views")
  .select("slug, count");

// Fetch contact messages using RPC
const { data: messagesData, error: messagesError } = await supabase.rpc(
  "get_contact_messages",
);

if (error) {
  console.error("Error fetching views:", error);
}

if (messagesError) {
  console.error("Error fetching messages:", messagesError);
}

// Create a map for easy lookup of view counts by slug
const viewsMap = new Map();
if (viewsData) {
  viewsData.forEach((view: any) => {
    viewsMap.set(view.slug, view.count);
  });
}

// Combine post data with view counts
const analyticsData = posts.map((post) => {
  const viewCount = viewsMap.get(post.slug) || 0;
  return {
    title: post.data.title,
    slug: post.slug,
    views: viewCount,
    pubDate: post.data.pubDate,
  };
});

// Sort by views descending
analyticsData.sort((a, b) => b.views - a.views);

// Calculate total views
const totalViews = analyticsData.reduce((acc, curr) => acc + curr.views, 0);
---

<Layout
  title="Analytics"
  description="Internal analytics dashboard"
  pageTitle="Analytics"
>
  <main class="p-6 md:p-12 max-w-4xl mx-auto min-h-screen">
    <div class="mb-8">
      <h1 class="text-4xl font-bold mb-2 righteous">Analytics Dashboard</h1>
      <p class="text-xl">
        Total Views: <span class="font-bold text-green-600">{totalViews}</span>
      </p>
    </div>

    <div
      class="bg-white border-2 border-black p-6 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]"
    >
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b-2 border-black">
              <th class="py-3 px-4 font-bold text-lg">Post Title</th>
              <th class="py-3 px-4 font-bold text-lg text-right">Views</th>
              <th
                class="py-3 px-4 font-bold text-lg text-right hidden md:table-cell"
                >Date</th
              >
            </tr>
          </thead>
          <tbody>
            {
              analyticsData.map((post) => (
                <tr class="border-b border-gray-300 hover:bg-gray-50 transition-colors">
                  <td class="py-3 px-4">
                    <a
                      href={`/blog/${post.slug}`}
                      class="hover:underline hover:text-blue-600 font-medium block"
                    >
                      {post.title}
                    </a>
                    <span class="text-xs text-gray-500 font-mono md:hidden">
                      {post.slug}
                    </span>
                  </td>
                  <td class="py-3 px-4 text-right font-mono font-bold text-lg">
                    {post.views}
                  </td>
                  <td class="py-3 px-4 text-right text-sm text-gray-600 hidden md:table-cell">
                    {post.pubDate.toLocaleDateString()}
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>

    {
      error && (
        <div class="mt-8 p-4 bg-red-100 border-l-4 border-red-500 text-red-700">
          <p class="font-bold">Error loading views data:</p>
          <p>{error.message}</p>
        </div>
      )
    }

    <div class="mt-16 mb-8">
      <h2 class="text-3xl font-bold mb-2 righteous">Contact Messages</h2>
      <p class="text-xl">
        Total Messages: <span class="font-bold text-green-600"
          >{messagesData ? messagesData.length : 0}</span
        >
      </p>
    </div>

    <div
      class="bg-white border-2 border-black p-6 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]"
    >
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b-2 border-black">
              <th class="py-3 px-4 font-bold text-lg">Name/Alias</th>
              <th class="py-3 px-4 font-bold text-lg">Email</th>
              <th class="py-3 px-4 font-bold text-lg">Link</th>
              <th class="py-3 px-4 font-bold text-lg">Manifesto</th>
              <th
                class="py-3 px-4 font-bold text-lg text-right hidden md:table-cell"
                >Date</th
              >
            </tr>
          </thead>
          <tbody>
            {
              messagesData &&
                messagesData.map((msg: any) => (
                  <tr class="border-b border-gray-300 hover:bg-gray-50 transition-colors align-top">
                    <td class="py-3 px-4 font-medium">{msg.nombre_alias}</td>
                    <td class="py-3 px-4 text-sm font-mono text-gray-600">
                      {msg.email}
                    </td>
                    <td class="py-3 px-4">
                      <a
                        href={msg.link_hallazgo}
                        target="_blank"
                        class="text-blue-600 hover:underline break-all text-sm"
                      >
                        Link
                      </a>
                    </td>
                    <td class="py-3 px-4 text-sm max-w-xs">
                      {msg.manifiesto_razon}
                    </td>
                    <td class="py-3 px-4 text-right text-sm text-gray-600 hidden md:table-cell whitespace-nowrap">
                      {new Date(msg.created_at).toLocaleDateString()}
                    </td>
                  </tr>
                ))
            }
            {
              (!messagesData || messagesData.length === 0) && (
                <tr>
                  <td colspan="5" class="py-8 text-center text-gray-500 italic">
                    No messages received yet.
                  </td>
                </tr>
              )
            }
          </tbody>
        </table>
      </div>
    </div>

    {
      messagesError && (
        <div class="mt-8 p-4 bg-red-100 border-l-4 border-red-500 text-red-700">
          <p class="font-bold">Error loading messages:</p>
          <p>{messagesError.message}</p>
        </div>
      )
    }
  </main>
</Layout>
